@model Players

<div class="container mt-4">
    <div class="row">
        
        <!-- 左邊：圖片 -->
        <div class="col-md-4 text-center">
            <img src="@Model.ImageURL" class="img-fluid rounded" style="max-height:300px;" />
        </div>

        <!-- 右邊：基本資料 -->
        <div class="col-md-8">
            <h2>@Model.PlayerName</h2>
            <hr />

            <p><strong>守備位置：</strong> @Model.Position</p>
            <p><strong>年齡：</strong> @Model.PlayAgo</p>
            <p><strong>國家：</strong> @Model.Country?.Name</p>
            <p><strong>簡介：</strong> @Model.PlayerDescription</p>
        </div>
    </div>

    <hr />

    <!-- 數據區 -->
    <h3>球員數據</h3>

    @if (Model.PlayerStats != null)
    {
        <table class="table table-bordered text-center">
            <thead class="table-dark">
                <tr>
                    <th>打擊率 (AVG)</th>
                    <th>全壘打 (HR)</th>
                    <th>打點 (RBI)</th>
                    <th>OPS</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.PlayerStats.AVG</td>
                    <td>@Model.PlayerStats.HR</td>
                    <td>@Model.PlayerStats.RBI</td>
                    <td>@Model.PlayerStats.OPS</td>
                </tr>
            </tbody>
        </table>
    }
    else
    {
        <p class="text-danger">尚未有數據資料</p>
    }

    <div class="mt-3">
        <a href="/user/home/index" class="btn btn-secondary">返回列表</a>
    </div>
</div>